FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY src/BlazorUI/BlazorUI.csproj src/BlazorUI/
RUN dotnet restore src/BlazorUI/BlazorUI.csproj

COPY src/BlazorUI/ src/BlazorUI/
RUN dotnet publish src/BlazorUI/BlazorUI.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
RUN mkdir -p /app/logs
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "BlazorUI.dll"]
