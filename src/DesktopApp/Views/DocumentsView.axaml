<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DesktopApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="vm:DocumentsViewModel"
             x:Class="DesktopApp.Views.DocumentsView">

  <DockPanel Margin="24">
    <TextBlock DockPanel.Dock="Top" 
               FontSize="24" 
               Text="База знаний" 
               FontWeight="Bold"
               Foreground="#1A1C19"
               Margin="0,0,0,24"/>

    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
      <Button Content="Загрузить документ" 
              Background="#3B8A7E"
              Foreground="#FFFFFF"
              CornerRadius="8"
              Padding="16, 10"
              FontWeight="Bold"
              Command="{Binding UploadDocumentCommand}" />
      <ProgressBar IsIndeterminate="True" 
                   IsVisible="{Binding IsUploading}" 
                   Width="100" 
                   VerticalAlignment="Center"/>
      <TextBlock Text="{Binding ErrorMessage}" 
                 Foreground="#D32F2F"
                 VerticalAlignment="Center"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
    
    <ListBox ItemsSource="{Binding Documents}" Background="Transparent" BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border CornerRadius="12" 
                  Background="#FFFFFF" 
                  BorderBrush="#E0EBE8"
                  BorderThickness="1"
                  Padding="16" Margin="0,4"
                  BoxShadow="0 2 10 0 #05000000">
            <Grid ColumnDefinitions="*, Auto, Auto">
              <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Filename}" 
                           FontSize="16" FontWeight="Medium" Foreground="#1A1C19"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding FilePath}" 
                           FontSize="12" 
                           Foreground="#707371"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"/>
                <TextBlock Text="{Binding UploadedAt, StringFormat='{}dd.MM.yyyy HH:mm'}" 
                           FontSize="12" 
                           Foreground="#707371"
                           Margin="0,4,0,0"/>
              </StackPanel>
              
              <Border Grid.Column="1" 
                      CornerRadius="16" 
                      Background="#E0EBE8"
                      Padding="12,4" 
                      Margin="16,0" 
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding Status}" 
                           FontSize="12" FontWeight="Medium"
                           Foreground="#444740"/>
              </Border>
              
              <Button Grid.Column="2" 
                      Content="Удалить" 
                      Background="Transparent"
                      Foreground="#D32F2F"
                      CornerRadius="8"
                      Command="{Binding $parent[UserControl].((vm:DocumentsViewModel)DataContext).DeleteDocumentCommand}" 
                      CommandParameter="{Binding}"
                      VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>