<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DesktopApp.ViewModels"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             x:DataType="vm:ChatViewModel"
             x:Class="DesktopApp.Views.ChatView">

  <UserControl.Styles>
    <Style Selector="Border.userMessage">
      <Setter Property="Background" Value="{DynamicResource MaterialPrimaryMidBrush}" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Border.userMessage TextBlock">
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Border.aiMessage">
      <Setter Property="Background" Value="{DynamicResource MaterialCardBackgroundBrush}" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*, Auto">
    
    <ListBox Grid.Row="0" ItemsSource="{Binding Messages}" Background="Transparent" Margin="16" BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border CornerRadius="12" 
                  Padding="16" Margin="0,8"
                  Classes.userMessage="{Binding IsUser}"
                  Classes.aiMessage="{Binding IsAi}">
            <StackPanel>
              <md:MarkdownScrollViewer Markdown="{Binding Text}">
                  <md:MarkdownScrollViewer.Styles>
                      <Style Selector="TextBlock">
                          <Setter Property="TextWrapping" Value="Wrap" />
                      </Style>
                  </md:MarkdownScrollViewer.Styles>
              </md:MarkdownScrollViewer>
                         
              <StackPanel IsVisible="{Binding HasSources}" Margin="0,16,0,0" HorizontalAlignment="Left">
                  <TextBlock Text="Источники:" FontWeight="Bold" Margin="0,0,0,8" />
                  <ItemsControl ItemsSource="{Binding Sources}">
                      <ItemsControl.ItemTemplate>
                          <DataTemplate>
                              <StackPanel Margin="0,4" HorizontalAlignment="Left">
                                  <Button Background="Transparent" 
                                          Padding="0" Margin="0" BorderThickness="0"
                                          Command="{Binding ToggleExpandedCommand}"
                                          HorizontalAlignment="Left">
                                      <StackPanel Orientation="Horizontal" Spacing="8">
                                          <TextBlock Text="-" VerticalAlignment="Center" />
                                          <TextBlock Text="{Binding DocumentName}" VerticalAlignment="Center" />
                                          <TextBlock Text="↑" IsVisible="{Binding IsExpanded}" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                                          <TextBlock Text="↓" IsVisible="{Binding !IsExpanded}" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                                      </StackPanel>
                                  </Button>
                                  
                                  <Border IsVisible="{Binding IsExpanded}" 
                                          Background="#0A000000" 
                                          CornerRadius="8" 
                                          Padding="12" 
                                          Margin="16,8,0,0">
                                      <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Classes="Body2" />
                                  </Border>
                              </StackPanel>
                          </DataTemplate>
                      </ItemsControl.ItemTemplate>
                  </ItemsControl>
              </StackPanel>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    
    <Border Grid.Row="1" 
            Background="{DynamicResource MaterialCardBackgroundBrush}" 
            Padding="16" 
            CornerRadius="16,16,0,0"
            BoxShadow="0 -2 10 0 #20000000">
        <Grid ColumnDefinitions="*, Auto">
        <TextBox Grid.Column="0" 
                 Text="{Binding UserInput}" 
                 Theme="{StaticResource OutlineTextBox}"
                 PlaceholderText="Задайте вопрос по документам..." 
                 AcceptsReturn="True" 
                 MaxHeight="120"
                 VerticalAlignment="Center"/>
        
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="16,0,0,0" VerticalAlignment="Center">
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsThinking}" 
                         Width="30" Height="30"
                         Classes="Circular"/>
            <Button Content="ОТПРАВИТЬ" 
                    Background="#89A595"
                    Foreground="#FFFFFF"
                    CornerRadius="8"
                    Command="{Binding SendMessageCommand}"/>
        </StackPanel>
        </Grid>
    </Border>
  </Grid>
</UserControl>
