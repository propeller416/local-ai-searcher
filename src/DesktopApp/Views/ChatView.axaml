<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DesktopApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             x:DataType="vm:ChatViewModel"
             x:Class="DesktopApp.Views.ChatView">

  <Grid RowDefinitions="Auto, *, Auto">
    
    <Border Grid.Row="0" Padding="16, 16, 16, 0">
        <TextBlock Classes="Headline6" 
                   Text="AI-Ассистент" 
                   FontWeight="Bold"
                   Foreground="#89A595"/>
    </Border>

    <ListBox Grid.Row="1" ItemsSource="{Binding Messages}" Background="Transparent" Margin="16" BorderThickness="0">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border CornerRadius="12" 
                  Background="{DynamicResource MaterialCardBackgroundBrush}"
                  Padding="16" Margin="0,8">
            <StackPanel>
              <TextBlock Text="{Binding Role}" 
                         Classes="Subtitle2" 
                         Foreground="{DynamicResource MaterialPrimaryMidBrush}"
                         Margin="0,0,0,8"/>
              <TextBlock Text="{Binding Text}" 
                         Classes="Body1" 
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    
    <Border Grid.Row="2" 
            Background="{DynamicResource MaterialCardBackgroundBrush}" 
            Padding="16" 
            CornerRadius="16,16,0,0"
            BoxShadow="0 -2 10 0 #20000000">
        <Grid ColumnDefinitions="*, Auto">
        <TextBox Grid.Column="0" 
                 Text="{Binding UserInput}" 
                 Theme="{StaticResource OutlineTextBox}"
                 PlaceholderText="Задайте вопрос по документам..." 
                 AcceptsReturn="True" 
                 MaxHeight="120"
                 VerticalAlignment="Center"/>
        
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="16,0,0,0" VerticalAlignment="Center">
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsThinking}" 
                         Width="30" Height="30"
                         Classes="Circular"/>
            <Button Content="ОТПРАВИТЬ" 
                    Background="#89A595"
                    Foreground="#FFFFFF"
                    CornerRadius="8"
                    Command="{Binding SendMessageCommand}"/>
        </StackPanel>
        </Grid>
    </Border>
  </Grid>
</UserControl>